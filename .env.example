# TMDB API v4 Read Access Token (Bearer)
# Получить: https://www.themoviedb.org/settings/api → "API Read Access Token"
VITE_TMDB_TOKEN=

# Google OAuth Client ID для Drive-синхронизации (опционально)
# Получить: https://console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=

# Base path для деплоя. Для GitHub Pages: /<repo-name>/
VITE_BASE_PATH=/moviebase/
